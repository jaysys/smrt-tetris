{
  "name": "tetris-webservice",
  "private": true,
  "packageManager": "pnpm@9.7.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@tetris/web",
    "dev:admin": "turbo run dev --filter=@tetris/admin",
    "dev:api": "turbo run dev --filter=@tetris/api",
    "start": "turbo run start --parallel",
    "start:api:test": "node scripts/start-api-test.mjs",
    "build": "turbo run build --concurrency=1",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "capture:screens": "playwright test tests/e2e/screenshot-capture.spec.ts",
    "lint": "turbo run lint",
    "db:reset": "node scripts/db-reset.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reseed": "node scripts/db-reseed.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "tsx": "4.20.3",
    "turbo": "2.5.6",
    "typescript": "5.8.3"
  }
}
